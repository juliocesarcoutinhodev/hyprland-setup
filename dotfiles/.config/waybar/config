{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 26,
  "margin-top": 10,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": [
    "clock",
    "hyprland/workspaces",
    "custom/media"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "pulseaudio",
    "pulseaudio#microphone",
    "network",
    "tray",
    "custom/power"
  ],
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Visual Studio Code": "ˇ░Ę×  VS Code",
      "(.*)Visual Studio Code": "ˇ░Ę×  VS Code",
      "(.*)Zen Browser": "´ëę  Zen Browser",
      "(.*) ÔÇö Zen Browser": "´ëę  Zen Browser",
      "(.*)Spotify": "´ć╝  Spotify",
      "(.*)Kitty": "´ĺë  Terminal"
    },
    "separate-outputs": true
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "active": " ´äĹ ",
      "default": " ´äĹ ",
      "urgent": " ´ü¬ ",
      "empty": " ´äĹ "
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/media": {
    "format": "{}",
    "return-type": "json",
    "max-length": 40,
    "escape": true,
    "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null",
    "on-click": "playerctl play-pause"
},
